import java.util.*;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        ArrayList<Integer> cart = new ArrayList<>();

        while (true) {
            int n = sc.nextInt();
            if (n == 0) break;
            cart.add(n);
        }

        int total = 0;

        for (int x : cart) {
            total += x;
            System.out.print(x + " ");
        }

        System.out.println();
        System.out.println("Total: " + total);
    }
}
